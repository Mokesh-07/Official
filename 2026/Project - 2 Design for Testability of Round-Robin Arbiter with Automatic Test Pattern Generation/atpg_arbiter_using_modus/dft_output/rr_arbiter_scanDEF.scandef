VERSION 5.5 ;
NAMESCASESENSITIVE ON ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN rr_arbiter ;

SCANCHAINS 1 ;
  - top_chain_seg1_clk_rising 
    + PARTITION p_clk_rising 
      MAXBITS 37
    + START PIN scan_in
    + FLOATING 
       grant_reg_reg[0] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[1] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[2] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[3] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[4] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[5] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[6] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[7] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[8] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[9] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[10] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[11] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[12] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[13] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[14] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[15] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[16] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[17] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[18] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[19] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[20] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[21] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[22] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[23] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[24] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[25] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[26] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[27] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[28] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[29] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[30] ( IN SI ) ( OUT Q ) 
       grant_reg_reg[31] ( IN SI ) ( OUT Q ) 
       pointer_reg[0] ( IN SI ) ( OUT Q ) 
       pointer_reg[1] ( IN SI ) ( OUT Q ) 
       pointer_reg[2] ( IN SI ) ( OUT Q ) 
       pointer_reg[3] ( IN SI ) ( OUT Q ) 
       pointer_reg[4] ( IN SI ) ( OUT Q ) 
    + STOP PIN scan_out
;

END SCANCHAINS 
